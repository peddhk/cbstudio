# CB Studio's - URL rewriting

# Página padrão
DirectoryIndex index.html index.php

# Esconde arquivos sensíveis
<FilesMatch "^\.|\.env$|_helpers\.php$">
  Require all denied
</FilesMatch>

# Habilita rewrite
RewriteEngine On

# Bloqueia acesso direto à pasta storage
RewriteRule ^storage/ - [F,L]

# Roteamento /api/...
RewriteRule ^api/upload/?$                          api/upload.php   [L]
RewriteRule ^api/status/([A-Z0-9-]+)/?$             api/status.php?key=$1   [L]
RewriteRule ^api/download/([A-Z0-9-]+)/?$           api/download.php?key=$1 [L]
RewriteRule ^api/view/([A-Z0-9-]+)/?$               api/view.php?key=$1     [L]
RewriteRule ^api/list/?$                            api/list.php     [L]

# Atalhos
RewriteRule ^admin/?$                               admin.html       [L]

# Aceita métodos PUT/DELETE/PATCH (compat InfinityFree)
<IfModule mod_headers.c>
  Header set X-Powered-By "CB Studio's"
</IfModule>

# Erro 404 amigável (cai no SPA)
ErrorDocument 404 /index.html
